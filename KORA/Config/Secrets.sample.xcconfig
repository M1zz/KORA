// Template for KORA/Config/Secrets.xcconfig (which is gitignored).
//
// 1. Copy this file to Secrets.xcconfig in the same directory.
// 2. Fill in your own developer keys.
// 3. Build — the values are injected into Info.plist via $(...) substitution
//    and read at runtime from Bundle.main.

KAKAO_REST_API_KEY = YOUR_KAKAO_REST_API_KEY
NAVER_CLIENT_ID = YOUR_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET = YOUR_NAVER_CLIENT_SECRET
ODSAY_API_KEY = YOUR_ODSAY_API_KEY
